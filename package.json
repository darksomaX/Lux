{
  "name": "lux",
  "version": "0.3.1",
  "description": "Lux. A self-hostable anti-censorship web proxy with a lock, cloak, encrypted vault, and engine switching.",
  "type": "module",
  "main": "server/index.js",
  "scripts": {
    "start": "node server/index.js",
    "dev": "node --watch server/index.js",
    "build": "node scripts/build-uv.mjs",
    "build:uv": "node scripts/build-uv.mjs",
    "test:block-sim": "node tests/block-sim/evasion.test.js",
    "test:vault": "node tests/vault/crypto.test.js",
    "test:e2e": "node tests/e2e/wisp-tunnel.test.js",
    "test:features": "node tests/features/harness.test.js",
    "test:browser": "node tests/browser/ui.test.mjs",
    "test": "node tests/block-sim/evasion.test.js && node tests/vault/crypto.test.js && node tests/e2e/wisp-tunnel.test.js && node tests/features/harness.test.js"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@mercuryworkshop/bare-mux": "^2.0.3",
    "@mercuryworkshop/epoxy-tls": "^2.1.19-1",
    "@mercuryworkshop/epoxy-transport": "^2.1.3",
    "@mercuryworkshop/libcurl-transport": "^2.0.5",
    "@mercuryworkshop/scramjet": "^1.1.0",
    "@mercuryworkshop/wisp-js": "^0.4.1",
    "@titaniumnetwork-dev/ultraviolet": "^3.2.7",
    "compression": "^1.8.1",
    "express": "^4.21.2"
  },
  "keywords": [
    "proxy",
    "ultraviolet",
    "scramjet",
    "anti-censorship",
    "wisp",
    "privacy"
  ],
  "license": "AGPL-3.0-or-later",
  "devDependencies": {
    "jsdom": "^29.1.1",
    "playwright": "^1.61.0"
  }
}
